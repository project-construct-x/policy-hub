{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration mocks",
    "start:dev": "ng serve --configuration development",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "e2e": "start-server-and-test start http://localhost:4200 \"cypress run\"",
    "e2e:open": "start-server-and-test start http://localhost:4200 \"cypress open\"",
    "cy:run": "cypress run",
    "cy:open": "cypress open",
    "docker:dev": "docker compose -f ../docker-compose.yml up --build"
  },
  "private": true,
  "packageManager": "npm@11.0.0",
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@jsverse/transloco": "^8.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "21.3.0",
    "cypress": "^15.12.0",
    "eslint": "^10.0.2",
    "jsdom": "^29.1.1",
    "miragejs": "^0.2.0-alpha.3",
    "prettier": "3.8.1",
    "start-server-and-test": "^3.0.11",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.1.10"
  }
}
